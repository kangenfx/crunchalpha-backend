// detectHighCorrelation detects multiple same-direction positions
func detectHighCorrelation(trades []TradeData) []RiskFlag {
	if len(trades) < 10 {
		return nil
	}
	
	maxSimultaneous := 0
	for i := 0; i < len(trades)-1; i++ {
		openPositions := 1
		for j := i + 1; j < len(trades) && j < i+20; j++ {
			if trades[j].OpenTime.Before(trades[i].CloseTime) {
				if trades[i].Type == trades[j].Type {
					openPositions++
				}
			}
		}
		if openPositions > maxSimultaneous {
			maxSimultaneous = openPositions
		}
	}
	
	if maxSimultaneous >= 5 {
		return []RiskFlag{{
			FlagType:  "HIGH_CORRELATION",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "HIGH_CORRELATION",
			Desc:      fmt.Sprintf("%d same-direction positions simultaneously", maxSimultaneous),
			ScoreText: "-15",
		}}
	}
	return nil
}

// detectGridTrading detects grid/hedging patterns
func detectGridTrading(trades []TradeData) []RiskFlag {
	if len(trades) < 20 {
		return nil
	}
	
	gridCount := 0
	for i := 1; i < len(trades) && i < 100; i++ {
		timeDiff := trades[i].OpenTime.Sub(trades[i-1].OpenTime)
		if timeDiff < 5*time.Minute && timeDiff > 0 {
			if trades[i].Lots == trades[i-1].Lots {
				if (trades[i].Type == "buy" && trades[i-1].Type == "sell") ||
				   (trades[i].Type == "sell" && trades[i-1].Type == "buy") {
					gridCount++
				}
			}
		}
	}
	
	if gridCount >= 10 {
		return []RiskFlag{{
			FlagType:  "GRID_TRADING",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "GRID_TRADING",
			Desc:      fmt.Sprintf("Grid/hedging pattern detected (%d instances)", gridCount),
			ScoreText: "-15",
		}}
	}
	return nil
}

// detectCommissionHeavy detects excessive scalping
func detectCommissionHeavy(trades []TradeData, grossProfit, grossLoss float64) []RiskFlag {
	if len(trades) < 50 {
		return nil
	}
	
	avgProfit := grossProfit / float64(len(trades))
	avgLoss := math.Abs(grossLoss) / float64(len(trades))
	
	if avgProfit < 5 && avgLoss < 5 {
		quickTrades := 0
		for _, t := range trades {
			duration := t.CloseTime.Sub(t.OpenTime)
			if duration < 5*time.Minute {
				quickTrades++
			}
		}
		
		pct := float64(quickTrades) / float64(len(trades)) * 100
		if pct > 50 {
			return []RiskFlag{{
				FlagType:  "COMMISSION_HEAVY",
				Severity:  "MINOR",
				Penalty:   10,
				Title:     "COMMISSION_HEAVY",
				Desc:      fmt.Sprintf("%.0f%% trades <5min (high commissions)", pct),
				ScoreText: "-10",
			}}
		}
	}
	return nil
}

// detectStrategyDrift detects changing trading patterns
func detectStrategyDrift(trades []TradeData) []RiskFlag {
	if len(trades) < 100 {
		return nil
	}
	
	mid := len(trades) / 2
	firstHalf := trades[:mid]
	secondHalf := trades[mid:]
	
	var firstAvgLot, secondAvgLot float64
	for _, t := range firstHalf {
		firstAvgLot += t.Lots
	}
	firstAvgLot /= float64(len(firstHalf))
	
	for _, t := range secondHalf {
		secondAvgLot += t.Lots
	}
	secondAvgLot /= float64(len(secondHalf))
	
	ratio := secondAvgLot / firstAvgLot
	if ratio > 3 || ratio < 0.33 {
		return []RiskFlag{{
			FlagType:  "STRATEGY_DRIFT",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "STRATEGY_DRIFT",
			Desc:      fmt.Sprintf("Lot size changed %.1fx (instability)", ratio),
			ScoreText: "-15",
		}}
	}
	return nil
}

