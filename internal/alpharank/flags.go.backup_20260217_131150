// detectLotInconsistency detects erratic lot size changes
func detectLotInconsistency(trades []TradeData) []RiskFlag {
	if len(trades) < 30 {
		return nil
	}
	
	// Calculate lot size volatility
	var lots []float64
	for _, t := range trades {
		if t.Lots > 0 {
			lots = append(lots, t.Lots)
		}
	}
	
	if len(lots) < 30 {
		return nil
	}
	
	// Calculate mean and std dev
	var sum, sumSq float64
	for _, lot := range lots {
		sum += lot
		sumSq += lot * lot
	}
	mean := sum / float64(len(lots))
	variance := (sumSq / float64(len(lots))) - (mean * mean)
	stdDev := math.Sqrt(variance)
	
	// If std dev > 100% of mean, lots are very inconsistent
	cv := (stdDev / mean) * 100
	if cv > 150 {
		return []RiskFlag{{
			FlagType:  "LOT_INCONSISTENCY",
			Severity:  "MINOR",
			Penalty:   10,
			Title:     "LOT_INCONSISTENCY",
			Desc:      fmt.Sprintf("Lot sizes vary %.0f%% (erratic sizing)", cv),
			ScoreText: "-10",
		}}
	}
	return nil
}

// detectHighFrequency detects excessive trading
func detectHighFrequency(trades []TradeData) []RiskFlag {
	if len(trades) < 100 {
		return nil
	}
	
	// Calculate trades per day
	if len(trades) == 0 {
		return nil
	}
	
	duration := trades[len(trades)-1].CloseTime.Sub(trades[0].OpenTime)
	days := duration.Hours() / 24
	
	if days < 1 {
		days = 1
	}
	
	tradesPerDay := float64(len(trades)) / days
	
	// If more than 50 trades per day on average
	if tradesPerDay > 50 {
		return []RiskFlag{{
			FlagType:  "HIGH_FREQUENCY",
			Severity:  "MINOR",
			Penalty:   10,
			Title:     "HIGH_FREQUENCY",
			Desc:      fmt.Sprintf("%.0f trades/day avg (overtrading)", tradesPerDay),
			ScoreText: "-10",
		}}
	}
	return nil
}

// detectPoorRiskReward detects bad risk/reward ratio
func detectPoorRiskReward(trades []TradeData) []RiskFlag {
	if len(trades) < 50 {
		return nil
	}
	
	var totalWins, totalLosses float64
	winCount, lossCount := 0, 0
	
	for _, t := range trades {
		if t.Profit > 0 {
			totalWins += t.Profit
			winCount++
		} else if t.Profit < 0 {
			totalLosses += math.Abs(t.Profit)
			lossCount++
		}
	}
	
	if winCount == 0 || lossCount == 0 {
		return nil
	}
	
	avgWin := totalWins / float64(winCount)
	avgLoss := totalLosses / float64(lossCount)
	
	rrRatio := avgWin / avgLoss
	
	// If average win < average loss (RR < 1)
	if rrRatio < 1.0 {
		return []RiskFlag{{
			FlagType:  "POOR_RISK_REWARD",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "POOR_RISK_REWARD",
			Desc:      fmt.Sprintf("Risk/Reward %.2f (avg win < avg loss)", rrRatio),
			ScoreText: "-15",
		}}
	}
	return nil
}

// detectMaxTradeSize detects position sizing too large
func detectMaxTradeSize(trades []TradeData, equity float64) []RiskFlag {
	if len(trades) < 10 || equity == 0 {
		return nil
	}
	
	// Find max single trade loss
	var maxLoss float64
	for _, t := range trades {
		if t.Profit < 0 && math.Abs(t.Profit) > maxLoss {
			maxLoss = math.Abs(t.Profit)
		}
	}
	
	// If single trade loss > 20% of equity
	lossPct := (maxLoss / equity) * 100
	if lossPct > 20 {
		return []RiskFlag{{
			FlagType:  "MAX_POSITION_SIZE",
			Severity:  "CRITICAL",
			Penalty:   25,
			Title:     "MAX_POSITION_SIZE",
			Desc:      fmt.Sprintf("Single trade lost %.1f%% of equity", lossPct),
			ScoreText: "-25",
		}}
	}
	return nil
}

// detectDrawdownRecovery detects poor recovery from drawdowns
func detectDrawdownRecovery(trades []TradeData) []RiskFlag {
	if len(trades) < 100 {
		return nil
	}
	
	// Track equity curve
	equity := 10000.0
	maxEquity := equity
	maxDD := 0.0
	_ = false
	longDrawdown := 0
	
	for _, t := range trades {
		equity += t.Profit
		
		if equity > maxEquity {
			maxEquity = equity
			// Recovery
			longDrawdown = 0
		} else {
			dd := ((maxEquity - equity) / maxEquity) * 100
			if dd > maxDD {
				maxDD = dd
			}
			
			if dd > 10 {
				// In drawdown
				longDrawdown++
			}
		}
	}
	
	// If spent >30% of trades in drawdown
	ddPct := (float64(longDrawdown) / float64(len(trades))) * 100
	if ddPct > 30 {
		return []RiskFlag{{
			FlagType:  "SLOW_RECOVERY",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "SLOW_RECOVERY",
			Desc:      fmt.Sprintf("In drawdown %.0f%% of time (slow recovery)", ddPct),
			ScoreText: "-15",
		}}
	}
	return nil
}

// detectSymbolConcentration detects trading only 1-2 symbols
func detectSymbolConcentration(trades []TradeData) []RiskFlag {
	if len(trades) < 30 {
		return nil
	}
	
	symbolCount := make(map[string]int)
	for _, t := range trades {
		symbolCount[t.Symbol]++
	}
	
	// If >80% trades on single symbol
	for symbol, count := range symbolCount {
		pct := float64(count) / float64(len(trades)) * 100
		if pct > 80 {
			return []RiskFlag{{
				FlagType:  "SYMBOL_CONCENTRATION",
				Severity:  "MINOR",
				Penalty:   10,
				Title:     "SYMBOL_CONCENTRATION",
				Desc:      fmt.Sprintf("%.0f%% trades on %s (lack of diversification)", pct, symbol),
				ScoreText: "-10",
			}}
		}
	}
	return nil
}

// detectNightTrading detects trading during low liquidity hours
func detectNightTrading(trades []TradeData) []RiskFlag {
	if len(trades) < 20 {
		return nil
	}
	
	nightTrades := 0
	for _, t := range trades {
		hour := t.OpenTime.UTC().Hour()
		// 22:00-06:00 UTC is typically low liquidity
		if hour >= 22 || hour <= 6 {
			nightTrades++
		}
	}
	
	pct := float64(nightTrades) / float64(len(trades)) * 100
	if pct > 40 {
		return []RiskFlag{{
			FlagType:  "NIGHT_TRADING",
			Severity:  "MINOR",
			Penalty:   10,
			Title:     "NIGHT_TRADING",
			Desc:      fmt.Sprintf("%.0f%% trades during low liquidity hours", pct),
			ScoreText: "-10",
		}}
	}
	return nil
}

// detectWinStreakDependency detects reliance on lucky streaks
func detectWinStreakDependency(trades []TradeData) []RiskFlag {
	if len(trades) < 50 {
		return nil
	}
	
	maxStreak := 0
	currentStreak := 0
	
	for _, t := range trades {
		if t.Profit > 0 {
			currentStreak++
			if currentStreak > maxStreak {
				maxStreak = currentStreak
			}
		} else {
			currentStreak = 0
		}
	}
	
	// If longest win streak > 30% of total trades
	streakPct := float64(maxStreak) / float64(len(trades)) * 100
	if streakPct > 30 {
		return []RiskFlag{{
			FlagType:  "WIN_STREAK_DEPENDENCY",
			Severity:  "MINOR",
			Penalty:   10,
			Title:     "WIN_STREAK_DEPENDENCY",
			Desc:      fmt.Sprintf("Profit relies on %d-trade win streak", maxStreak),
			ScoreText: "-10",
		}}
	}
	return nil
}

// detectAveragingDown detects adding to losing positions
func detectAveragingDown(trades []TradeData) []RiskFlag {
	if len(trades) < 30 {
		return nil
	}
	
	avgDownCount := 0
	
	// Look for same symbol, same direction, increasing lot after loss
	for i := 1; i < len(trades) && i < 200; i++ {
		if trades[i-1].Profit < 0 {
			// Same symbol, same direction, larger lot
			if trades[i].Symbol == trades[i-1].Symbol &&
			   trades[i].Type == trades[i-1].Type &&
			   trades[i].Lots > trades[i-1].Lots {
				avgDownCount++
			}
		}
	}
	
	if avgDownCount >= 5 {
		return []RiskFlag{{
			FlagType:  "AVERAGING_DOWN",
			Severity:  "CRITICAL",
			Penalty:   25,
			Title:     "AVERAGING_DOWN",
			Desc:      fmt.Sprintf("Adding to losers %d times (dangerous)", avgDownCount),
			ScoreText: "-25",
		}}
	}
	return nil
}

// detectExcessiveHedging detects simultaneous opposite positions
func detectExcessiveHedging(trades []TradeData) []RiskFlag {
	if len(trades) < 30 {
		return nil
	}
	
	hedgeCount := 0
	
	for i := 1; i < len(trades) && i < 200; i++ {
		// Check if opened within 1 minute, same symbol, opposite direction
		timeDiff := trades[i].OpenTime.Sub(trades[i-1].OpenTime)
		if timeDiff < time.Minute && timeDiff > 0 {
			if trades[i].Symbol == trades[i-1].Symbol {
				if (trades[i].Type == "buy" && trades[i-1].Type == "sell") ||
				   (trades[i].Type == "sell" && trades[i-1].Type == "buy") {
					hedgeCount++
				}
			}
		}
	}
	
	pct := float64(hedgeCount) / float64(len(trades)) * 100
	if pct > 20 {
		return []RiskFlag{{
			FlagType:  "EXCESSIVE_HEDGING",
			Severity:  "MAJOR",
			Penalty:   15,
			Title:     "EXCESSIVE_HEDGING",
			Desc:      fmt.Sprintf("%.0f%% trades are hedged (complicates risk)", pct),
			ScoreText: "-15",
		}}
