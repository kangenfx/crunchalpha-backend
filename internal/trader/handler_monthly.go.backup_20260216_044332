package trader

import (
	"net/http"
	"time"
	
	"github.com/gin-gonic/gin"
)

// GetMonthlyPerformance returns monthly aggregated performance
func (h *Handler) GetMonthlyPerformance(c *gin.Context) {
	accountID := c.Query("account_id")
	if accountID == "" {
		c.JSON(http.StatusBadRequest, gin.H{"error": "account_id required"})
		return
	}
	
	userID, exists := c.Get("user_id")
	if !exists {
		c.JSON(http.StatusUnauthorized, gin.H{"error": "unauthorized"})
		return
	}
	
	// Verify account ownership
	_, err := h.service.repo.GetAccountByID(accountID, userID.(string))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "account not found"})
		return
	}
	
	// Generate monthly performance data
	// Will be replaced with real calculations from trades table
	months := generateMonthlyData()
	
	c.JSON(http.StatusOK, gin.H{
		"account_id": accountID,
		"months":     months,
		"period":     "6M",
	})
}

func generateMonthlyData() []map[string]interface{} {
	now := time.Now()
	months := []map[string]interface{}{}
	
	monthNames := []string{"Jan", "Feb", "Mar", "Apr", "May", "Jun"}
	baseProfits := []float64{1250, -340, 2100, 890, 1560, -180}
	
	for i := 0; i < 6; i++ {
		month := now.AddDate(0, -5+i, 0)
		
		months = append(months, map[string]interface{}{
			"month":    monthNames[i],
			"year":     month.Year(),
			"profit":   baseProfits[i],
			"trades":   35 + (i * 3),
			"winRate":  45.0 + float64(i*4),
			"wins":     20 + (i * 2),
			"losses":   15 + i,
		})
	}
	
	return months
}
