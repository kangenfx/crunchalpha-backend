func (h *Handler) CreateSignalSet(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	var count int
	h.DB.QueryRow(`SELECT COUNT(*) FROM analyst_signal_sets WHERE analyst_id=$1`, uid).Scan(&count)
	if count >= 2 { c.JSON(400, gin.H{"ok": false, "error": "max 2 signal sets per analyst"}); return }
	var req struct{ Name string `json:"name"` }
	if err := c.ShouldBindJSON(&req); err != nil { c.JSON(400, gin.H{"ok": false, "error": "invalid json"}); return }
	req.Name = strings.TrimSpace(req.Name)
	if req.Name == "" { c.JSON(400, gin.H{"ok": false, "error": "name required"}); return }
	id := genSetID(req.Name)
	var s SignalSetDTO
	err := h.DB.QueryRow(`INSERT INTO analyst_signal_sets (id, analyst_id, name, status)
		VALUES ($1, $2, $3, 'Active') RETURNING id, name, status`, id, uid, req.Name).Scan(&s.ID, &s.Name, &s.Status)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db insert failed"}); return }
	c.JSON(200, gin.H{"ok": true, "signalSet": s})
}

func (h *Handler) UpdateSignalSet(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	setID := c.Param("id")
	var req struct{ Name string `json:"name"` }
	if err := c.ShouldBindJSON(&req); err != nil { c.JSON(400, gin.H{"ok": false, "error": "invalid json"}); return }
	req.Name = strings.TrimSpace(req.Name)
	if req.Name == "" { c.JSON(400, gin.H{"ok": false, "error": "name required"}); return }
	res, err := h.DB.Exec(`UPDATE analyst_signal_sets SET name=$1, updated_at=now()
		WHERE id=$2 AND analyst_id=$3`, req.Name, setID, uid)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db update failed"}); return }
	aff, _ := res.RowsAffected()
	if aff == 0 { c.JSON(404, gin.H{"ok": false, "error": "signal set not found"}); return }
	c.JSON(200, gin.H{"ok": true, "id": setID, "name": req.Name})
}

func (h *Handler) ListSignals(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	rows, err := h.DB.Query(`
SELECT s.id, COALESCE(s.set_id,''), COALESCE(ss.name,''), s.pair, s.direction,
  s.entry, s.sl, s.tp, s.status, COALESCE(s.issued_at,''), COALESCE(s.analyst_name,''),
  COALESCE(s.notes,'')
FROM analyst_signals s
LEFT JOIN analyst_signal_sets ss ON ss.id = s.set_id
WHERE s.analyst_id=$1 ORDER BY s.id DESC LIMIT 500`, uid)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db query failed"}); return }
	defer rows.Close()
	out := make([]SignalRow, 0)
	for rows.Next() {
		var s SignalRow
		if err := rows.Scan(&s.ID, &s.SetID, &s.SetName, &s.Pair, &s.Direction,
			&s.Entry, &s.SL, &s.TP, &s.Status, &s.IssuedAt, &s.Analyst, &s.Notes); err != nil {
			c.JSON(500, gin.H{"ok": false, "error": "db scan failed"}); return
		}
		s.RR = calcRR(s.Entry, s.SL, s.TP, s.Direction)
		if s.Status == "CLOSED_TP" { s.Result = "WIN" } else if s.Status == "CLOSED_SL" { s.Result = "LOSS" }
		out = append(out, s)
	}
	c.JSON(200, gin.H{"ok": true, "signals": out})
}

func (h *Handler) CreateSignal(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	var req struct {
		Pair        string `json:"pair"`
		Direction   string `json:"direction"`
		Entry       string `json:"entry"`
		SL          string `json:"sl"`
		TP          string `json:"tp"`
		SetID       string `json:"setId"`
		AnalystName string `json:"analystName"`
		Notes       string `json:"notes"`
		MarketPrice string `json:"marketPrice"`
	}
	if err := c.ShouldBindJSON(&req); err != nil { c.JSON(400, gin.H{"ok": false, "error": "invalid json"}); return }
	req.Pair = strings.ToUpper(strings.TrimSpace(req.Pair))
	req.Direction = strings.ToUpper(strings.TrimSpace(req.Direction))
	req.Entry = strings.TrimSpace(req.Entry)
	req.SL = strings.TrimSpace(req.SL)
	req.TP = strings.TrimSpace(req.TP)
	req.SetID = strings.TrimSpace(req.SetID)
	if req.Pair == "" || (req.Direction != "BUY" && req.Direction != "SELL") ||
		req.Entry == "" || req.SL == "" || req.TP == "" {
		c.JSON(400, gin.H{"ok": false, "error": "pair/direction/entry/sl/tp required"}); return
	}
	if req.SetID == "" { c.JSON(400, gin.H{"ok": false, "error": "setId required"}); return }

	// Hard floor R:R >= 0.5
	rr := calcRR(req.Entry, req.SL, req.TP, req.Direction)
	if rr < 0.5 {
		c.JSON(400, gin.H{"ok": false, "error": fmt.Sprintf("R:R %.2f below minimum 0.5 — rejected", rr)}); return
	}

	// Spam: max 10 signals/24h
	var recentCount int
	h.DB.QueryRow(`SELECT COUNT(*) FROM analyst_signals
		WHERE analyst_id=$1 AND created_at > NOW() - INTERVAL '24 hours'`, uid).Scan(&recentCount)
	if recentCount >= 10 { c.JSON(400, gin.H{"ok": false, "error": "max 10 signals per 24 hours"}); return }

	var setOwner string
	err := h.DB.QueryRow(`SELECT analyst_id FROM analyst_signal_sets WHERE id=$1`, req.SetID).Scan(&setOwner)
	if err != nil || setOwner != uid { c.JSON(400, gin.H{"ok": false, "error": "signal set not found or unauthorized"}); return }

	analystName := strings.TrimSpace(req.AnalystName)
	if analystName == "" { analystName = "Analyst" }
	issuedAt := time.Now().Format("2006-01-02 15:04")
	var id int64
	// Auto-lookup market price from EA cache
	marketPrice := strings.TrimSpace(req.MarketPrice)
	if marketPrice == "" {
		var bid, ask float64
		err2 := h.DB.QueryRow(`SELECT bid, ask FROM ea_price_cache WHERE pair=$1`,
			req.Pair).Scan(&bid, &ask)
		if err2 == nil {
			// Use mid price
			mid := (bid + ask) / 2.0
			marketPrice = strconv.FormatFloat(mid, 'f', 5, 64)
		} else {
			marketPrice = "0"
		}
	}
	err = h.DB.QueryRow(`INSERT INTO analyst_signals
		(analyst_id, set_id, pair, direction, entry, sl, tp, status, issued_at, analyst_name, notes, market_price_at_creation)
		VALUES ($1,$2,$3,$4,$5,$6,$7,'PENDING',$8,$9,$10,$11) RETURNING id`,
		uid, req.SetID, req.Pair, req.Direction, req.Entry, req.SL, req.TP,
		issuedAt, analystName, strings.TrimSpace(req.Notes), marketPrice).Scan(&id)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": fmt.Sprintf("db insert failed: %v", err)}); return }
	c.JSON(200, gin.H{"ok": true, "signal": SignalRow{
		ID: id, SetID: req.SetID, Pair: req.Pair, Direction: req.Direction,
		Entry: req.Entry, SL: req.SL, TP: req.TP,
		Status: "PENDING", IssuedAt: issuedAt, Analyst: analystName, Notes: req.Notes, RR: rr,
	}})
}

func (h *Handler) UpdateSignal(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	sigID, err := strconv.ParseInt(c.Param("id"), 10, 64)
	if err != nil || sigID <= 0 { c.JSON(400, gin.H{"ok": false, "error": "invalid signal id"}); return }
	var currentStatus string
	err = h.DB.QueryRow(`SELECT status FROM analyst_signals WHERE id=$1 AND analyst_id=$2`, sigID, uid).Scan(&currentStatus)
	if err != nil { c.JSON(404, gin.H{"ok": false, "error": "signal not found"}); return }
	if currentStatus != "PENDING" && currentStatus != "OPEN" {
		c.JSON(400, gin.H{"ok": false, "error": "only PENDING signals can be edited"}); return
	}
	var req struct {
		Entry string `json:"entry"`; SL string `json:"sl"`; TP string `json:"tp"`; Notes string `json:"notes"`
	}
	if err := c.ShouldBindJSON(&req); err != nil { c.JSON(400, gin.H{"ok": false, "error": "invalid json"}); return }
	req.Entry = strings.TrimSpace(req.Entry); req.SL = strings.TrimSpace(req.SL); req.TP = strings.TrimSpace(req.TP)
	if req.Entry == "" || req.SL == "" || req.TP == "" { c.JSON(400, gin.H{"ok": false, "error": "entry/sl/tp required"}); return }
	_, err = h.DB.Exec(`UPDATE analyst_signals SET entry=$1, sl=$2, tp=$3, notes=$4, updated_at=now()
		WHERE id=$5 AND analyst_id=$6`, req.Entry, req.SL, req.TP, req.Notes, sigID, uid)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db update failed"}); return }
	c.JSON(200, gin.H{"ok": true, "updated": sigID})
}

func (h *Handler) CancelSignal(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	sigID, err := strconv.ParseInt(c.Param("id"), 10, 64)
	if err != nil || sigID <= 0 { c.JSON(400, gin.H{"ok": false, "error": "invalid signal id"}); return }
	res, err := h.DB.Exec(`UPDATE analyst_signals SET status='CANCELLED_MANUAL', updated_at=now()
		WHERE id=$1 AND analyst_id=$2 AND status IN ('PENDING','OPEN')`, sigID, uid)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db update failed"}); return }
	aff, _ := res.RowsAffected()
	if aff == 0 { c.JSON(400, gin.H{"ok": false, "error": "signal not found or not cancellable"}); return }
	c.JSON(200, gin.H{"ok": true, "updated": aff})
}

func (h *Handler) Performance(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }
	var totalSignals, wins, losses int
	var totalRR, grossProfit, grossLoss float64
	rows, err := h.DB.Query(`SELECT status, entry, sl, tp, direction FROM analyst_signals
		WHERE analyst_id=$1 AND status IN ('CLOSED_TP','CLOSED_SL')`, uid)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db query failed"}); return }
	defer rows.Close()
	for rows.Next() {
		var status, entry, sl, tp, direction string
		rows.Scan(&status, &entry, &sl, &tp, &direction)
		totalSignals++
		rr := calcRR(entry, sl, tp, direction)
		totalRR += rr
		if status == "CLOSED_TP" { wins++; grossProfit += rr } else { losses++; grossLoss += 1.0 }
	}
	winRate := 0.0
	if totalSignals > 0 { winRate = math.Round(float64(wins)/float64(totalSignals)*10000) / 100 }
	avgRR := 0.0
	if totalSignals > 0 { avgRR = math.Round(totalRR/float64(totalSignals)*100) / 100 }
	pf := 0.0
	if grossLoss > 0 { pf = math.Round(grossProfit/grossLoss*100) / 100 }
	var pendingCount, runningCount int
	h.DB.QueryRow(`SELECT COUNT(*) FILTER (WHERE status='PENDING'), COUNT(*) FILTER (WHERE status='RUNNING')
		FROM analyst_signals WHERE analyst_id=$1`, uid).Scan(&pendingCount, &runningCount)
	c.JSON(200, gin.H{"ok": true, "performance": gin.H{
		"totalSignals": totalSignals, "wins": wins, "losses": losses,
		"winRate": winRate, "profitFactor": pf, "avgRR": avgRR,
		"pendingSignals": pendingCount, "runningSignals": runningCount,
	}})
}

func (h *Handler) AnalystAlphaRank(c *gin.Context) {
	uid, ok := mustAnalyst(c)
	if !ok { return }

	// Per-signal-set support
	setId := strings.TrimSpace(c.Query("setId"))
	if setId != "" {
		var owner string
		if err := h.DB.QueryRow(`SELECT analyst_id FROM analyst_signal_sets WHERE id=$1`, setId).Scan(&owner); err != nil || owner != uid {
			c.JSON(403, gin.H{"ok": false, "error": "signal set not found or unauthorized"})
			return
		}
	}

	type sigData struct {
		direction string; entry string; sl string; tp string
		status string; pair string; createdAt time.Time
	}

	var rows *sql.Rows
	var err error
	if setId != "" {
		rows, err = h.DB.Query(`SELECT direction, entry, sl, tp, status, pair, created_at
			FROM analyst_signals WHERE analyst_id=$1 AND set_id=$2 ORDER BY created_at ASC`, uid, setId)
	} else {
		rows, err = h.DB.Query(`SELECT direction, entry, sl, tp, status, pair, created_at
			FROM analyst_signals WHERE analyst_id=$1 ORDER BY created_at ASC`, uid)
	}
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": "db error"}); return }
	defer rows.Close()

	var allSigs []sigData
	for rows.Next() {
		var sd sigData
		rows.Scan(&sd.direction, &sd.entry, &sd.sl, &sd.tp, &sd.status, &sd.pair, &sd.createdAt)
		allSigs = append(allSigs, sd)
	}

	totalSignals := len(allSigs)
	var closedSignals, wins, losses int
	var totalClosedRR, grossProfit, grossLoss float64
	var totalAllRR float64
	var validRRCount int
	slMap := make(map[string][]float64)
	var recentCount24h int
	now := time.Now()
	pairSet := make(map[string]bool)

	// Weekly signal map for consistency
	weeklyMap := make(map[string]int)
	var firstSignalTime, lastSignalTime time.Time

	for i, sd := range allSigs {
		rr := calcRR(sd.entry, sd.sl, sd.tp, sd.direction)
		pairSet[sd.pair] = true

		if i == 0 { firstSignalTime = sd.createdAt }
		lastSignalTime = sd.createdAt

		year, week := sd.createdAt.ISOWeek()
		key := fmt.Sprintf("%d-%d", year, week)
		weeklyMap[key]++

		if now.Sub(sd.createdAt) <= 24*time.Hour { recentCount24h++ }

		eVal, _ := strconv.ParseFloat(sd.entry, 64)
		slVal, _ := strconv.ParseFloat(sd.sl, 64)
		if eVal > 0 && slVal > 0 {
			slMap[sd.pair] = append(slMap[sd.pair], math.Abs(eVal-slVal))
		}

		if rr >= 0.5 { totalAllRR += rr; validRRCount++ }

		if sd.status == "CLOSED_TP" || sd.status == "CLOSED_SL" {
			closedSignals++
			totalClosedRR += rr
			if sd.status == "CLOSED_TP" {
				wins++
				e2,_ := strconv.ParseFloat(sd.entry,64)
				tp2,_ := strconv.ParseFloat(sd.tp,64)
				grossProfit += math.Abs(tp2-e2)
			} else {
				losses++
				e2,_ := strconv.ParseFloat(sd.entry,64)
				sl2,_ := strconv.ParseFloat(sd.sl,64)
				grossLoss += math.Abs(e2-sl2)
			}
		}
	}

	winRate := 0.0
	if closedSignals > 0 { winRate = float64(wins) / float64(closedSignals) * 100 }
	avgClosedRR := 0.0
	if closedSignals > 0 { avgClosedRR = totalClosedRR / float64(closedSignals) }
	pf := 0.0
	if grossLoss > 0 { pf = grossProfit / grossLoss }
	avgAllRR := 0.0
	if validRRCount > 0 { avgAllRR = totalAllRR / float64(validRRCount) }

	// ── P1: Profitability — Win Rate × Avg R:R (proxy return) ──
	// Same name as trader P1, but calculated from signal wins × rr
	p1Raw := winRate / 100.0 * avgClosedRR // e.g. 60% × 1.5 = 0.9
	var p1Score float64
	switch {
	case p1Raw >= 1.2: p1Score = 100
	case p1Raw >= 0.9: p1Score = 85
	case p1Raw >= 0.6: p1Score = 70
	case p1Raw >= 0.3: p1Score = 45
	case closedSignals == 0: p1Score = 0
	default: p1Score = math.Max(0, p1Raw/0.3*45)
	}

	// ── P2: Consistency — regular weekly signal activity ──
	// Count weeks with at least 1 signal vs total weeks in range
	var p2Score float64
	if closedSignals == 0 {
		p2Score = 0
	} else if closedSignals < 2 {
		p2Score = 0
	} else {
		totalWeeks := int(lastSignalTime.Sub(firstSignalTime).Hours()/168) + 1
		activeWeeks := len(weeklyMap)
		consistencyRate := float64(activeWeeks) / float64(totalWeeks) * 100
		switch {
		case consistencyRate >= 80: p2Score = 100
		case consistencyRate >= 60: p2Score = 80
		case consistencyRate >= 40: p2Score = 60
		case consistencyRate >= 20: p2Score = 35
		default: p2Score = 10
		}
	}

	// ── P3: Risk Management — flags penalty based ──
	flags := []AnalystFlag{}
	var p3Score float64
	if closedSignals == 0 {
		p3Score = 0
	} else {
		p3Score = 100.0
	}

	// Flag 1: Low win rate
	if closedSignals >= 5 && winRate < 40 {
		f := AnalystFlag{Code:"LOW_ACCURACY", Severity:"MAJOR", Title:"Low Win Rate",
			Desc: fmt.Sprintf("Win rate %.1f%% below 40%% threshold", winRate), Penalty: 15}
		flags = append(flags, f); p3Score -= f.Penalty
	}
	// Flag 2: Poor avg R:R on closed signals
	if closedSignals >= 3 && avgClosedRR < 0.8 {
		f := AnalystFlag{Code:"POOR_RR", Severity:"MAJOR", Title:"Poor Risk-Reward",
			Desc: fmt.Sprintf("Avg R:R 1:%.2f is below 0.8 threshold", avgClosedRR), Penalty: 12}
		flags = append(flags, f); p3Score -= f.Penalty
	}
	// Flag 3: Spam
	if recentCount24h > 10 {
		f := AnalystFlag{Code:"SPAM_SIGNALS", Severity:"MINOR", Title:"Excessive Signals",
			Desc: fmt.Sprintf("%d signals sent in last 24h", recentCount24h), Penalty: 8}
		flags = append(flags, f); p3Score -= f.Penalty
	}
	// Flag 4: Inconsistent sizing
	for pair, slList := range slMap {
		if len(slList) >= 3 {
			avg := 0.0
			for _, v := range slList { avg += v }
			avg /= float64(len(slList))
			maxDev := 0.0
			for _, v := range slList {
				if d := math.Abs(v-avg)/avg*100; d > maxDev { maxDev = d }
			}
			if maxDev > 200 {
				f := AnalystFlag{Code:"INCONSISTENT_SIZING", Severity:"MINOR", Title:"Inconsistent Risk Sizing",
					Desc: fmt.Sprintf("%s SL varies by %.0f%%", pair, maxDev), Penalty: 5}
				flags = append(flags, f); p3Score -= f.Penalty
				break
			}
		}
	}
	if p3Score < 0 { p3Score = 0 }

	// ── P4: Recovery — max consecutive losses (lower = better) ──
	maxConsecLoss := 0; curConsec := 0
	for _, sd := range allSigs {
		if sd.status == "CLOSED_SL" { curConsec++; if curConsec > maxConsecLoss { maxConsecLoss = curConsec } } else if sd.status == "CLOSED_TP" { curConsec = 0 }
	}
	var p4Score float64
	if closedSignals == 0 {
		p4Score = 0
	} else {
		switch {
		case maxConsecLoss == 0: p4Score = 100
		case maxConsecLoss <= 2: p4Score = 85
		case maxConsecLoss <= 4: p4Score = 65
		case maxConsecLoss <= 6: p4Score = 40
		default: p4Score = math.Max(0, 100-float64(maxConsecLoss)*10)
		}
	}

	// ── P5: Trading Edge — Profit Factor ──
	var p5Score float64
	switch {
	case pf >= 2.0: p5Score = 100
	case pf >= 1.5: p5Score = 85
	case pf >= 1.2: p5Score = 70
	case pf >= 1.0: p5Score = 50
	case closedSignals == 0: p5Score = 0
	default: p5Score = math.Max(0, pf/1.0*50)
	}

	// ── P6: Discipline — avg RR from CLOSED signals only ──
	var p6Score float64
	if closedSignals == 0 {
		p6Score = 0
	} else {
		p6Score = math.Min(100, avgClosedRR/1.0*100)
		p6Score = math.Round(p6Score*10) / 10
	}

	// ── P7: Track Record — days active + signal volume ──
	uniquePairs := len(pairSet)
	var p7Score float64
	if closedSignals == 0 {
		p7Score = 0
	} else {
		daysActive := int(now.Sub(firstSignalTime).Hours() / 24)
		sigScore := 0.0
		switch {
		case closedSignals >= 50: sigScore = 100
		case closedSignals >= 20: sigScore = 80
		case closedSignals >= 10: sigScore = 60
		case closedSignals >= 5:  sigScore = 40
		default:                  sigScore = float64(closedSignals) / 5.0 * 40
		}
		dayScore := 0.0
		switch {
		case daysActive >= 365: dayScore = 100
		case daysActive >= 180: dayScore = 85
		case daysActive >= 90:  dayScore = 70
		case daysActive >= 30:  dayScore = 50
		case daysActive >= 7:   dayScore = 30
		default:                dayScore = 10
		}
		p7Score = sigScore*0.5 + dayScore*0.5
	}

	// ── Data Quality Flags ──
	if closedSignals < 5 {
		flags = append(flags, AnalystFlag{Code:"INSUFFICIENT_DATA", Severity:"INFO",
			Title:"Insufficient Data",
			Desc:fmt.Sprintf("Only %d closed signal(s). Need 20 for full score.", closedSignals),
			Penalty:0})
	} else if closedSignals < 20 {
		flags = append(flags, AnalystFlag{Code:"LIMITED_SAMPLE", Severity:"INFO",
			Title:"Limited Sample",
			Desc:fmt.Sprintf("%d closed signals. Need 20 for full score.", closedSignals),
			Penalty:0})
	}
	disciplineScore := p6Score // P6 Discipline already calculated above

	// ── Final AlphaScore (7 pillars equal weight ~14.3% each) ──
	// Weights: P1=15, P2=15, P3=15, P4=15, P5=15, P6=10, P7=10, Discipline=5 → total=100
	alphaScore := p1Score*0.15 + p2Score*0.15 + p3Score*0.15 + p4Score*0.15 +
		p5Score*0.15 + p6Score*0.10 + p7Score*0.10 + disciplineScore*0.05
	alphaScore = math.Round(alphaScore*10) / 10

	var pendingCount, runningCount int
	if setId != "" {
		h.DB.QueryRow(`SELECT COUNT(*) FILTER (WHERE status='PENDING' OR status='OPEN'), COUNT(*) FILTER (WHERE status='RUNNING') FROM analyst_signals WHERE analyst_id=$1 AND set_id=$2`, uid, setId).Scan(&pendingCount, &runningCount)
	} else {
		h.DB.QueryRow(`SELECT COUNT(*) FILTER (WHERE status='PENDING' OR status='OPEN'), COUNT(*) FILTER (WHERE status='RUNNING') FROM analyst_signals WHERE analyst_id=$1`, uid).Scan(&pendingCount, &runningCount)
	}

	c.JSON(200, gin.H{
		"ok": true,
		"alphaRank": gin.H{
			"setId":     setId,
			"alphaScore":     alphaScore,
			"grade":          calcGrade(alphaScore),
			"totalSignals":   totalSignals,
			"closedSignals":  closedSignals,
			"wins":           wins,
			"losses":         losses,
			"winRate":        math.Round(winRate*100) / 100,
			"avgRR":          math.Round(avgClosedRR*100) / 100,
			"avgAllRR":       math.Round(avgAllRR*100) / 100,
			"profitFactor":   math.Round(pf*100) / 100,
				"totalPipsWin":   math.Round(grossProfit*100)/100,
				"totalPipsLoss":  math.Round(grossLoss*100)/100,
			"maxConsecLoss":  maxConsecLoss,
			"uniquePairs":    uniquePairs,
			"pendingSignals": pendingCount,
			"runningSignals": runningCount,
			"pillars": []gin.H{
				{"code":"P1","name":"Profitability","weight":15,"score":math.Round(p1Score*10)/10,
					"reason":fmt.Sprintf("WinRate %.1f%% × AvgRR %.2f = %.2f", winRate, avgClosedRR, p1Raw)},
				{"code":"P2","name":"Consistency","weight":15,"score":math.Round(p2Score*10)/10,
					"reason":fmt.Sprintf("%d active weeks of %d total weeks", len(weeklyMap), int(lastSignalTime.Sub(firstSignalTime).Hours()/168)+1)},
				{"code":"P3","name":"Risk Management","weight":15,"score":math.Round(p3Score*10)/10,
					"reason":fmt.Sprintf("%d flag(s) detected", len(flags))},
				{"code":"P4","name":"Recovery","weight":15,"score":math.Round(p4Score*10)/10,
					"reason":fmt.Sprintf("Max consecutive losses: %d", maxConsecLoss)},
				{"code":"P5","name":"Trading Edge","weight":15,"score":math.Round(p5Score*10)/10,
					"reason":fmt.Sprintf("Profit factor %.2f", pf)},
				{"code":"P6","name":"Discipline","weight":10,"score":math.Round(p6Score*10)/10,
					"reason":fmt.Sprintf("Avg R:R all signals 1:%.2f", avgAllRR)},
				{"code":"P7","name":"Track Record","weight":10,"score":math.Round(p7Score*10)/10,
					"reason":fmt.Sprintf("%d days active, %d signals", int(now.Sub(firstSignalTime).Hours()/24), totalSignals)},
			},
			"flags":           flags,
			"flagCount":       len(flags),
			"disciplineScore": math.Round(disciplineScore*10) / 10,
		},
	})
}

// GET /api/public/marketplace - no auth required
