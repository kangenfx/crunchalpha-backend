		items = append(items, it)
	}
	if items == nil { items = []SetItem{} }

	c.JSON(200, gin.H{"ok": true, "sets": items, "count": len(items)})
}

// Helper: calculate AlphaRank for any setId (used by marketplace)
type AlphaResult struct { Score float64; Grade string }

func (h *Handler) calcAlphaRank(setId string) AlphaResult {
	rows, err := h.DB.Query(`SELECT direction, entry, sl, tp, status FROM analyst_signals WHERE set_id=$1`, setId)
	if err != nil { return AlphaResult{0, "D"} }
	defer rows.Close()

	var wins, losses, total int
	var grossProfit, grossLoss float64

	for rows.Next() {
		var dir, entry, sl, tp, status string
		rows.Scan(&dir, &entry, &sl, &tp, &status)
		if status != "CLOSED_TP" && status != "CLOSED_SL" { continue }
		total++
		e, _ := strconv.ParseFloat(entry, 64)
		s, _ := strconv.ParseFloat(sl, 64)
		t, _ := strconv.ParseFloat(tp, 64)
		if status == "CLOSED_TP" {
			wins++
			grossProfit += math.Abs(t - e)
		} else {
			losses++
			grossLoss += math.Abs(e - s)
		}
	}

	if total == 0 { return AlphaResult{0, "D"} }

	winRate := float64(wins) / float64(total) * 100
	pf := 0.0
	if grossLoss > 0 { pf = grossProfit / grossLoss }

	// Pillar scores (simplified 4 pillars for marketplace)
	p1 := winRate * 0.35                          // Win Rate 35%
	p2 := math.Min(pf/3.0, 1.0) * 30             // Profit Factor 30%
	p3 := math.Min(float64(total)/10.0, 1.0) * 20 // Volume 20%
	p4 := 0.0
	if pf >= 1.5 && winRate >= 50 { p4 = 15 } else if pf >= 1.0 { p4 = 7 } // Consistency 15%

	score := math.Round((p1+p2+p3+p4)*10) / 10
	if score > 100 { score = 100 }

	grade := "D"
	switch {
	case score >= 90: grade = "A+"
	case score >= 85: grade = "A"
	case score >= 80: grade = "A-"
	case score >= 75: grade = "B+"
	case score >= 70: grade = "B"
	case score >= 65: grade = "B-"
	case score >= 60: grade = "C+"
	case score >= 55: grade = "C"
	}
	return AlphaResult{score, grade}
}

// RecalcAndSaveAlphaRank — identical 7-pillar logic, saves to DB
// Call this whenever a signal status changes to CLOSED_TP or CLOSED_SL
func (h *Handler) RecalcAndSaveAlphaRank(setId string) {
	type sigData struct{ direction,entry,sl,tp,status,pair string; createdAt time.Time }
	rows, err := h.DB.Query(`SELECT direction,entry,sl,tp,status,pair,created_at FROM analyst_signals WHERE set_id=$1 ORDER BY created_at ASC`, setId)
	if err != nil { return }
	defer rows.Close()
	var allSigs []sigData
	for rows.Next() {
		var sd sigData
		rows.Scan(&sd.direction,&sd.entry,&sd.sl,&sd.tp,&sd.status,&sd.pair,&sd.createdAt)
		allSigs = append(allSigs, sd)
	}
	var closedSignals,wins,losses int
	var grossProfit,grossLoss,totalClosedRR,totalAllRR float64
	var validRRCount,recentCount24h int
	slMap := make(map[string][]float64)
	weeklyMap := make(map[string]int)
	pairSet := make(map[string]bool)
	var firstSignalTime,lastSignalTime time.Time
	now := time.Now()
	for i,sd := range allSigs {
		rr := calcRR(sd.entry,sd.sl,sd.tp,sd.direction)
		pairSet[sd.pair]=true
		if i==0 { firstSignalTime=sd.createdAt }
		lastSignalTime=sd.createdAt
		y,w := sd.createdAt.ISOWeek()
		weeklyMap[fmt.Sprintf("%d-%d",y,w)]++
		if now.Sub(sd.createdAt)<=24*time.Hour { recentCount24h++ }
		eVal,_:=strconv.ParseFloat(sd.entry,64); slVal,_:=strconv.ParseFloat(sd.sl,64)
		if eVal>0&&slVal>0 { slMap[sd.pair]=append(slMap[sd.pair],math.Abs(eVal-slVal)) }
		if rr>=0.5 { totalAllRR+=rr; validRRCount++ }
		if sd.status=="CLOSED_TP"||sd.status=="CLOSED_SL" {
			closedSignals++; totalClosedRR+=rr
			if sd.status=="CLOSED_TP" { wins++; e2,_:=strconv.ParseFloat(sd.entry,64); tp2,_:=strconv.ParseFloat(sd.tp,64); grossProfit+=math.Abs(tp2-e2) } else { losses++; e2,_:=strconv.ParseFloat(sd.entry,64); sl2,_:=strconv.ParseFloat(sd.sl,64); grossLoss+=math.Abs(e2-sl2) }
		}
	}
	_ = losses
	winRate:=0.0; if closedSignals>0 { winRate=float64(wins)/float64(closedSignals)*100 }
	avgClosedRR:=0.0; if closedSignals>0 { avgClosedRR=totalClosedRR/float64(closedSignals) }
	pf:=0.0; if grossLoss>0 { pf=grossProfit/grossLoss }
	_ = totalAllRR; _ = validRRCount; _ = recentCount24h

	// P1
	p1Raw:=winRate/100.0*avgClosedRR; var p1Score float64
	switch { case p1Raw>=1.2:p1Score=100; case p1Raw>=0.9:p1Score=85; case p1Raw>=0.6:p1Score=70; case p1Raw>=0.3:p1Score=45; case closedSignals==0:p1Score=0; default:p1Score=math.Max(0,p1Raw/0.3*45) }
	// P2
	var p2Score float64
	if closedSignals>=2 { totalWeeks:=int(lastSignalTime.Sub(firstSignalTime).Hours()/168)+1; cr:=float64(len(weeklyMap))/float64(totalWeeks)*100; switch { case cr>=80:p2Score=100; case cr>=60:p2Score=80; case cr>=40:p2Score=60; case cr>=20:p2Score=35; default:p2Score=10 } }
	// P3
	p3Score:=0.0; if closedSignals>0 { p3Score=100 }
	if closedSignals>=5&&winRate<40 { p3Score-=15 }
	if closedSignals>=3&&avgClosedRR<0.8 { p3Score-=12 }
	for _,slList:=range slMap { if len(slList)>=3 { avg:=0.0; for _,v:=range slList{avg+=v}; avg/=float64(len(slList)); maxDev:=0.0; for _,v:=range slList{if d:=math.Abs(v-avg)/avg*100;d>maxDev{maxDev=d}}; if maxDev>200{p3Score-=5;break} } }
	if p3Score<0 { p3Score=0 }
	// P4
	maxCL:=0; cur:=0; for _,sd:=range allSigs { if sd.status=="CLOSED_SL"{cur++;if cur>maxCL{maxCL=cur}}else if sd.status=="CLOSED_TP"{cur=0} }
	var p4Score float64; if closedSignals>0 { switch { case maxCL==0:p4Score=100; case maxCL<=2:p4Score=85; case maxCL<=4:p4Score=65; case maxCL<=6:p4Score=40; default:p4Score=math.Max(0,100-float64(maxCL)*10) } }
	// P5
	var p5Score float64; switch { case pf>=2.0:p5Score=100; case pf>=1.5:p5Score=85; case pf>=1.2:p5Score=70; case pf>=1.0:p5Score=50; case closedSignals==0:p5Score=0; default:p5Score=math.Max(0,pf/1.0*50) }
	// P6
	p6Score:=0.0; if closedSignals>0 { p6Score=math.Min(100,avgClosedRR/1.0*100) }
	// P7
	var p7Score float64
	if closedSignals>0 {
		daysActive:=int(now.Sub(firstSignalTime).Hours()/24)
		sigScore:=0.0; switch { case closedSignals>=50:sigScore=100; case closedSignals>=20:sigScore=80; case closedSignals>=10:sigScore=60; case closedSignals>=5:sigScore=40; default:sigScore=float64(closedSignals)/5.0*40 }
		dayScore:=0.0; switch { case daysActive>=365:dayScore=100; case daysActive>=180:dayScore=85; case daysActive>=90:dayScore=70; case daysActive>=30:dayScore=50; case daysActive>=7:dayScore=30; default:dayScore=10 }
		p7Score=sigScore*0.5+dayScore*0.5
	}
	alphaScore:=math.Round((p1Score*0.15+p2Score*0.15+p3Score*0.15+p4Score*0.15+p5Score*0.15+p6Score*0.10+p7Score*0.10+p6Score*0.05)*10)/10
	grade:="D"
	switch { case alphaScore>=90:grade="A+"; case alphaScore>=85:grade="A"; case alphaScore>=80:grade="A-"; case alphaScore>=75:grade="B+"; case alphaScore>=70:grade="B"; case alphaScore>=65:grade="B-"; case alphaScore>=60:grade="C+"; case alphaScore>=55:grade="C" }

	h.DB.Exec(`UPDATE analyst_signal_sets SET alpha_score=$1, alpha_grade=$2, alpha_updated_at=now(), win_rate=$3, total_signals=$4, winning_signals=$5, profit_factor=$6 WHERE id=$7`, alphaScore, grade, math.Round(winRate*100)/100, closedSignals, wins, math.Round(pf*100)/100, setId)
}

// POST /api/admin/recalc-alpharank — one-time recalc all sets
func (h *Handler) AdminRecalcAllAlphaRank(c *gin.Context) {
	rows, err := h.DB.Query(`SELECT id FROM analyst_signal_sets WHERE UPPER(status)='ACTIVE'`)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": err.Error()}); return }
	defer rows.Close()
	var setIDs []string
	for rows.Next() {
		var id string; rows.Scan(&id)
		setIDs = append(setIDs, id)
	}
	for _, id := range setIDs {
		h.RecalcAndSaveAlphaRank(id)
	}
	c.JSON(200, gin.H{"ok": true, "recalculated": len(setIDs), "setIds": setIDs})
}

// GET /api/public/analyst-profile/:setId — no auth required
// All data from DB — zero on-the-fly calculation
func (h *Handler) GetPublicAnalystProfile(c *gin.Context) {
	setId := c.Param("setId")
	if setId == "" {
		c.JSON(400, gin.H{"ok": false, "error": "setId required"})
		return
	}

	// 1. Signal set info + analyst name
	type SetInfo struct {
		ID           string  `json:"id"`
		Name         string  `json:"name"`
		AnalystName  string  `json:"analystName"`
		Status       string  `json:"status"`
		CreatedAt    string  `json:"createdAt"`
		AlphaScore   float64 `json:"alphaScore"`
		AlphaGrade   string  `json:"alphaGrade"`
	}
	var set SetInfo
	err := h.DB.QueryRow(`
		SELECT ss.id, ss.name,
			COALESCE(NULLIF(u.name,''), split_part(u.email,'@',1)) as analyst_name,
			ss.status,
			COALESCE(ss.created_at::text,''),
			COALESCE(ss.alpha_score,0),
			COALESCE(ss.alpha_grade,'D')
		FROM analyst_signal_sets ss
		LEFT JOIN users u ON u.id::text = ss.analyst_id
		WHERE ss.id = $1`, setId).Scan(
		&set.ID, &set.Name, &set.AnalystName, &set.Status,
		&set.CreatedAt, &set.AlphaScore, &set.AlphaGrade)
	if err != nil {
		c.JSON(404, gin.H{"ok": false, "error": "signal set not found"})
		return
	}

	// 2. Summary stats from closed signals only (DB query, no calc)
	type SummaryStats struct {
		TotalSignals   int     `json:"totalSignals"`
		ClosedSignals  int     `json:"closedSignals"`
		Wins           int     `json:"wins"`
		Losses         int     `json:"losses"`
		WinRate        float64 `json:"winRate"`
		PendingSignals int     `json:"pendingSignals"`
		RunningSignals int     `json:"runningSignals"`
		Subscribers    int     `json:"subscribers"`
	}
	var stats SummaryStats
	h.DB.QueryRow(`
		SELECT
			COUNT(*) as total,
			COUNT(*) FILTER (WHERE status IN ('CLOSED_TP','CLOSED_SL')) as closed,
			COUNT(*) FILTER (WHERE status='CLOSED_TP') as wins,
			COUNT(*) FILTER (WHERE status='CLOSED_SL') as losses,
			COUNT(*) FILTER (WHERE status='PENDING') as pending,
			COUNT(*) FILTER (WHERE status='RUNNING') as running
		FROM analyst_signals WHERE set_id=$1`, setId).Scan(
		&stats.TotalSignals, &stats.ClosedSignals, &stats.Wins, &stats.Losses,
		&stats.PendingSignals, &stats.RunningSignals)
	if stats.ClosedSignals > 0 {
		stats.WinRate = math.Round(float64(stats.Wins)/float64(stats.ClosedSignals)*10000) / 100
	}
	h.DB.QueryRow(`SELECT COUNT(DISTINCT investor_id) FROM analyst_subscriptions WHERE set_id=$1 AND status='ACTIVE'`, setId).Scan(&stats.Subscribers)

	// 3. Computed metrics from closed signals (avg RR, PF, pips) — from DB
	type Metrics struct {
		AvgRR        float64 `json:"avgRR"`
		ProfitFactor float64 `json:"profitFactor"`
		TotalPipsWin float64 `json:"totalPipsWin"`
		TotalPipsLoss float64 `json:"totalPipsLoss"`
		NetPips      float64 `json:"netPips"`
		MaxConsecLoss int    `json:"maxConsecLoss"`
		AvgSignalMonth float64 `json:"avgSignalMonth"`
		AvgSignalWeek  float64 `json:"avgSignalWeek"`
		AvgTP          float64 `json:"avgTP"`
		AvgSL          float64 `json:"avgSL"`
		CumulativeR    float64 `json:"cumulativeR"`
	}
	var metrics Metrics

	// Compute from closed signals
	sigRows, err := h.DB.Query(`
		SELECT direction, entry, sl, tp, status, issued_at
		FROM analyst_signals
		WHERE set_id=$1 AND status IN ('CLOSED_TP','CLOSED_SL')
		ORDER BY id ASC`, setId)
	if err == nil {
		defer sigRows.Close()
		var totalRR, grossProfit, grossLoss, totalTP, totalSL float64
		var count int
		var firstDate, lastDate time.Time
		maxCL, curCL := 0, 0
		for sigRows.Next() {
			var dir, entry, sl, tp, status, issuedAt string
			sigRows.Scan(&dir, &entry, &sl, &tp, &status, &issuedAt)
			rr := calcRR(entry, sl, tp, dir)
			totalRR += rr
			count++
			e, _ := strconv.ParseFloat(entry, 64)
			s, _ := strconv.ParseFloat(sl, 64)
			t, _ := strconv.ParseFloat(tp, 64)
			tpDist := math.Abs(t - e)
			slDist := math.Abs(e - s)
			totalTP += tpDist
			totalSL += slDist
			if status == "CLOSED_TP" {
				grossProfit += tpDist
				curCL = 0
			} else {
				grossLoss += slDist
				curCL++
				if curCL > maxCL { maxCL = curCL }
			}
			// parse date for avg/month calc
			parsed, _ := time.Parse("2006-01-02 15:04", issuedAt)
			if firstDate.IsZero() { firstDate = parsed }
			lastDate = parsed
		}
		if count > 0 {
			metrics.AvgRR = math.Round(totalRR/float64(count)*100) / 100
			metrics.AvgTP = math.Round(totalTP/float64(count)*100) / 100
			metrics.AvgSL = math.Round(totalSL/float64(count)*100) / 100
			metrics.CumulativeR = math.Round(totalRR*100) / 100
		}
		if grossLoss > 0 {
			metrics.ProfitFactor = math.Round(grossProfit/grossLoss*100) / 100
		}
		metrics.TotalPipsWin = math.Round(grossProfit*100) / 100
		metrics.TotalPipsLoss = math.Round(grossLoss*100) / 100
		metrics.NetPips = math.Round((grossProfit-grossLoss)*100) / 100
		metrics.MaxConsecLoss = maxCL
		if !firstDate.IsZero() && !lastDate.IsZero() {
			days := lastDate.Sub(firstDate).Hours()/24 + 1
			months := days / 30.44
			weeks := days / 7
			if months > 0 { metrics.AvgSignalMonth = math.Round(float64(count)/months*10) / 10 }
			if weeks > 0 { metrics.AvgSignalWeek = math.Round(float64(count)/weeks*10) / 10 }
		}
	}

	// 4. Pillars — recalc inline same as AnalystAlphaRank (source of truth)
	// Reuse RecalcAndSaveAlphaRank logic but return pillars (not save)
	type PillarItem struct {
		Code   string  `json:"code"`
		Name   string  `json:"name"`
		Score  float64 `json:"score"`
		Weight int     `json:"weight"`
		Reason string  `json:"reason"`
	}

	// Build pillars from same logic — pull all signals for this set
	allRows, _ := h.DB.Query(`
		SELECT direction, entry, sl, tp, status, pair, created_at
		FROM analyst_signals WHERE set_id=$1 ORDER BY created_at ASC`, setId)
	var pillars []PillarItem
	var flags []AnalystFlag
	if allRows != nil {
		defer allRows.Close()
		type sd struct{ direction, entry, sl, tp, status, pair string; createdAt time.Time }
		var allSigs []sd
		for allRows.Next() {
			var s sd
			allRows.Scan(&s.direction, &s.entry, &s.sl, &s.tp, &s.status, &s.pair, &s.createdAt)
			allSigs = append(allSigs, s)
		}
		closed, wins2, losses2 := 0, 0, 0
		var grossP, grossL, totalCRR, totalAR float64
		var vRR int
		slMap2 := make(map[string][]float64)
		weekMap := make(map[string]int)
		pairSet2 := make(map[string]bool)
		var firstT, lastT time.Time
		maxCL2, curCL2 := 0, 0
		now2 := time.Now()
		_ = losses2
		for i, s := range allSigs {
			rr := calcRR(s.entry, s.sl, s.tp, s.direction)
			pairSet2[s.pair] = true
			if i == 0 { firstT = s.createdAt }
			lastT = s.createdAt
			y, w := s.createdAt.ISOWeek()
			weekMap[fmt.Sprintf("%d-%d", y, w)]++
			eV, _ := strconv.ParseFloat(s.entry, 64)
			sV, _ := strconv.ParseFloat(s.sl, 64)
			if eV > 0 && sV > 0 { slMap2[s.pair] = append(slMap2[s.pair], math.Abs(eV-sV)) }
			if rr >= 0.5 { totalAR += rr; vRR++ }
			if s.status == "CLOSED_TP" || s.status == "CLOSED_SL" {
				closed++; totalCRR += rr
				if s.status == "CLOSED_TP" {
					wins2++; curCL2 = 0
					e2, _ := strconv.ParseFloat(s.entry, 64); t2, _ := strconv.ParseFloat(s.tp, 64)
					grossP += math.Abs(t2 - e2)
				} else {
					losses2++; curCL2++; if curCL2 > maxCL2 { maxCL2 = curCL2 }
					e2, _ := strconv.ParseFloat(s.entry, 64); sl2, _ := strconv.ParseFloat(s.sl, 64)
					grossL += math.Abs(e2 - sl2)
				}
			}
		}
		_ = totalAR; _ = vRR
		wr2 := 0.0; if closed > 0 { wr2 = float64(wins2) / float64(closed) * 100 }
		avgCRR2 := 0.0; if closed > 0 { avgCRR2 = totalCRR / float64(closed) }
		pf2 := 0.0; if grossL > 0 { pf2 = grossP / grossL }
		p1r := wr2 / 100.0 * avgCRR2
		p1s := 0.0; switch { case p1r >= 1.2: p1s = 100; case p1r >= 0.9: p1s = 85; case p1r >= 0.6: p1s = 70; case p1r >= 0.3: p1s = 45; case closed == 0: p1s = 0; default: p1s = math.Max(0, p1r/0.3*45) }
		p2s := 0.0; if closed >= 2 { tw := int(lastT.Sub(firstT).Hours()/168) + 1; cr := float64(len(weekMap)) / float64(tw) * 100; switch { case cr >= 80: p2s = 100; case cr >= 60: p2s = 80; case cr >= 40: p2s = 60; case cr >= 20: p2s = 35; default: p2s = 10 } }
		p3s := 0.0; if closed > 0 { p3s = 100 }
		if closed >= 5 && wr2 < 40 { f := AnalystFlag{Code: "LOW_ACCURACY", Severity: "MAJOR", Title: "Low Win Rate", Desc: fmt.Sprintf("Win rate %.1f%% below 40%%", wr2), Penalty: 15}; flags = append(flags, f); p3s -= 15 }
		if closed >= 3 && avgCRR2 < 0.8 { f := AnalystFlag{Code: "POOR_RR", Severity: "MAJOR", Title: "Poor Risk-Reward", Desc: fmt.Sprintf("Avg R:R 1:%.2f below 0.8", avgCRR2), Penalty: 12}; flags = append(flags, f); p3s -= 12 }
		for _, sl3 := range slMap2 { if len(sl3) >= 3 { avg3 := 0.0; for _, v := range sl3 { avg3 += v }; avg3 /= float64(len(sl3)); mx := 0.0; for _, v := range sl3 { if d := math.Abs(v-avg3) / avg3 * 100; d > mx { mx = d } }; if mx > 200 { f := AnalystFlag{Code: "INCONSISTENT_SIZING", Severity: "MINOR", Title: "Inconsistent Risk Sizing", Desc: fmt.Sprintf("SL varies by %.0f%%", mx), Penalty: 5}; flags = append(flags, f); p3s -= 5; break } } }
		if p3s < 0 { p3s = 0 }
		p4s := 0.0; if closed > 0 { switch { case maxCL2 == 0: p4s = 100; case maxCL2 <= 2: p4s = 85; case maxCL2 <= 4: p4s = 65; case maxCL2 <= 6: p4s = 40; default: p4s = math.Max(0, 100-float64(maxCL2)*10) } }
		p5s := 0.0; switch { case pf2 >= 2.0: p5s = 100; case pf2 >= 1.5: p5s = 85; case pf2 >= 1.2: p5s = 70; case pf2 >= 1.0: p5s = 50; case closed == 0: p5s = 0; default: p5s = math.Max(0, pf2/1.0*50) }
		p6s := 0.0; if closed > 0 { p6s = math.Min(100, avgCRR2/1.0*100) }
		p7s := 0.0; if closed > 0 {
			da := int(now2.Sub(firstT).Hours() / 24)
			ss2 := 0.0; switch { case closed >= 50: ss2 = 100; case closed >= 20: ss2 = 80; case closed >= 10: ss2 = 60; case closed >= 5: ss2 = 40; default: ss2 = float64(closed) / 5.0 * 40 }
			ds2 := 0.0; switch { case da >= 365: ds2 = 100; case da >= 180: ds2 = 85; case da >= 90: ds2 = 70; case da >= 30: ds2 = 50; case da >= 7: ds2 = 30; default: ds2 = 10 }
			p7s = ss2*0.5 + ds2*0.5
		}
		_ = pairSet2
		daysAct := 0; if !firstT.IsZero() { daysAct = int(now2.Sub(firstT).Hours() / 24) }
		pillars = []PillarItem{
			{Code: "P1", Name: "Profitability", Weight: 15, Score: math.Round(p1s*10)/10, Reason: fmt.Sprintf("WinRate %.1f%% × AvgRR %.2f = %.2f", wr2, avgCRR2, p1r)},
			{Code: "P2", Name: "Consistency", Weight: 15, Score: math.Round(p2s*10)/10, Reason: fmt.Sprintf("%d active weeks of %d total", len(weekMap), int(lastT.Sub(firstT).Hours()/168)+1)},
			{Code: "P3", Name: "Risk Management", Weight: 15, Score: math.Round(p3s*10)/10, Reason: fmt.Sprintf("%d flag(s) detected", len(flags))},
			{Code: "P4", Name: "Recovery", Weight: 15, Score: math.Round(p4s*10)/10, Reason: fmt.Sprintf("Max consecutive losses: %d", maxCL2)},
			{Code: "P5", Name: "Trading Edge", Weight: 15, Score: math.Round(p5s*10)/10, Reason: fmt.Sprintf("Profit factor %.2f", pf2)},
			{Code: "P6", Name: "Discipline", Weight: 10, Score: math.Round(p6s*10)/10, Reason: fmt.Sprintf("Avg R:R 1:%.2f", avgCRR2)},
			{Code: "P7", Name: "Track Record", Weight: 10, Score: math.Round(p7s*10)/10, Reason: fmt.Sprintf("%d days active, %d signals", daysAct, stats.TotalSignals)},
		}
		if closed < 5 {
			flags = append(flags, AnalystFlag{Code: "INSUFFICIENT_DATA", Severity: "INFO", Title: "Insufficient Data", Desc: fmt.Sprintf("Only %d closed signals. Need 20 for full score.", closed), Penalty: 0})
		} else if closed < 20 {
			flags = append(flags, AnalystFlag{Code: "LIMITED_SAMPLE", Severity: "INFO", Title: "Limited Sample", Desc: fmt.Sprintf("%d closed signals. Need 20 for full score.", closed), Penalty: 0})
		}
	}
	if pillars == nil { pillars = []PillarItem{} }
	if flags == nil { flags = []AnalystFlag{} }

	// 5. Signal history (closed only — public view)
	type SigHistory struct {
		ID        int64   `json:"id"`
		Pair      string  `json:"pair"`
		Direction string  `json:"direction"`
		Entry     string  `json:"entry"`
		SL        string  `json:"sl"`
		TP        string  `json:"tp"`
		Status    string  `json:"status"`
		IssuedAt  string  `json:"issuedAt"`
		RR        float64 `json:"rr"`
		Result    string  `json:"result"`
		Pips      float64 `json:"pips"`
	}
	histRows, _ := h.DB.Query(`
		SELECT id, pair, direction, entry, sl, tp, status, COALESCE(issued_at,'')
		FROM analyst_signals
		WHERE set_id=$1 AND status IN ('CLOSED_TP','CLOSED_SL')
		ORDER BY id DESC LIMIT 50`, setId)
	var history []SigHistory
	if histRows != nil {
		defer histRows.Close()
		for histRows.Next() {
			var s SigHistory
			histRows.Scan(&s.ID, &s.Pair, &s.Direction, &s.Entry, &s.SL, &s.TP, &s.Status, &s.IssuedAt)
			s.RR = calcRR(s.Entry, s.SL, s.TP, s.Direction)
			if s.Status == "CLOSED_TP" {
				s.Result = "WIN"
				e, _ := strconv.ParseFloat(s.Entry, 64); t, _ := strconv.ParseFloat(s.TP, 64)
				s.Pips = math.Round(math.Abs(t-e)*100) / 100
			} else {
				s.Result = "LOSS"
				e, _ := strconv.ParseFloat(s.Entry, 64); sl, _ := strconv.ParseFloat(s.SL, 64)
				s.Pips = -math.Round(math.Abs(e-sl)*100) / 100
			}
			history = append(history, s)
		}
	}
	if history == nil { history = []SigHistory{} }

	c.JSON(200, gin.H{
		"ok":      true,
		"set":     set,
		"stats":   stats,
		"metrics": metrics,
		"pillars": pillars,
		"flags":   flags,
		"history": history,
	})
}
