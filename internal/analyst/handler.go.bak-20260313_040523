		FROM analyst_signal_sets s
		LEFT JOIN users u ON u.id::text = s.analyst_id
		LEFT JOIN analyst_subscriptions sub ON sub.set_id = s.id
		WHERE UPPER(s.status) = 'ACTIVE'
		GROUP BY s.id, s.name, s.analyst_id, u.name, u.email, s.created_at,
		         s.alpha_score, s.alpha_grade, s.win_rate, s.total_signals, s.winning_signals, s.profit_factor
		ORDER BY s.alpha_score DESC
	`)
	if err != nil { c.JSON(500, gin.H{"ok": false, "error": err.Error()}); return }
	defer rows.Close()

	type SetItem struct {
		ID             string  `json:"id"`
		Name           string  `json:"name"`
		AnalystID      string  `json:"analystId"`
		AnalystName    string  `json:"analystName"`
		Subscribers    int     `json:"subscribers"`
		TotalSignals   int     `json:"totalSignals"`
		WinningSignals int     `json:"winningSignals"`
		WinRate        float64 `json:"winRate"`
		ProfitFactor   float64 `json:"profitFactor"`
		AlphaScore     float64 `json:"alphaScore"`
		AlphaGrade     string  `json:"alphaGrade"`
		CreatedAt      string  `json:"createdAt"`
	}

	var items []SetItem
	for rows.Next() {
		var it SetItem
		var analystName sql.NullString
		var createdAtTime sql.NullTime
		rows.Scan(&it.ID, &it.Name, &it.AnalystID, &analystName,
			&it.Subscribers, &createdAtTime,
			&it.AlphaScore, &it.AlphaGrade,
			&it.WinRate, &it.TotalSignals, &it.WinningSignals, &it.ProfitFactor)
